# ============================================================
# VLearning — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VLearning

# ── Multi-tenant Domain ────────────────────────────────────
# Root domain for subdomain detection.
# Dev: localhost:3000 | Prod: ticoclass.com
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Service-role secret — bypasses RLS, used by Server Actions that need admin
# auth APIs (e.g. creating teacher accounts via auth.admin.createUser).
# NEVER expose to the browser. Dashboard → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ── Email (Gmail SMTP) ──────────────────────────────────────
# Used by lib/email/sender.ts to send teacher-credential / password
# emails. Enable 2-Step Verification on the Google account, then create
# an App Password at https://myaccount.google.com/apppasswords.
# Free Gmail: ~500/day. Workspace: ~2000/day.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.account@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx    # 16-char App Password, spaces optional
SMTP_FROM=your.account@gmail.com     # or "Name <addr@gmail.com>"

# ── Landing-page feedback inbox ─────────────────────────────
# Where the landing page's "Gửi góp ý" form delivers emails to.
# Read by app/actions/feedback.ts (server-only). Optional — there's a
# safe fallback inside the action file, but set this in production so
# you don't have to redeploy to change the inbox.
FEEDBACK_TO_EMAIL=you@example.com

# ── PayOS (thanh toán + xuất hoá đơn điện tử) ───────────────
# Dashboard: https://my.payos.vn → Cài đặt → Kênh thanh toán → API Key.
# Webhook URL phải đăng ký riêng ở Dashboard → Webhook URL với giá trị:
#   https://<your-domain>/api/v1/payments/payos/webhook
# Tích hợp sInvoice (Viettel) làm qua UI Workflow trên PayOS Dashboard
# sau khi đã có tài khoản sInvoice — không cần env var riêng.
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
